{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "cd ../.. && HUSKY=0 pnpm install --prod=false",
  "buildCommand": "cd ../.. && pnpm --filter @calendly/shared build && pnpm --filter @calendly/server build",
  "outputDirectory": "public",
  "functions": {
    "api/index.ts": {
      "includeFiles": "dist/**,prisma/**"
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }]
}
