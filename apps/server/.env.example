# Server
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# CORS - comma separated list of allowed origins
CORS_ORIGINS=http://localhost:5173

# Database (MySQL)
# Local:
DATABASE_URL="mysql://root:password@localhost:3306/calendly"
# Railway on Vercel (append these params for serverless):
# DATABASE_URL="mysql://USER:PASS@HOST:PORT/railway?connection_limit=1&connect_timeout=15&pool_timeout=15&sslaccept=accept_invalid_certs&allowPublicKeyRetrieval=true"

# Optional — Gmail notification emails after booking (both required to send)
# EMAIL_USER="you@gmail.com"
# EMAIL_PASS="your-app-password"

# Optional — link target for "View event in Calendly" (defaults to first CORS origin)
# WEB_APP_URL="http://localhost:5173"
